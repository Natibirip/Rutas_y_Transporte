<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controladores.MainController"
            prefHeight="700.0" prefWidth="1000.0">

    <left>
        <VBox spacing="15.0" style="-fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Gestión de Rutas" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Separator />

            <Label text="Origen:"/>
            <ComboBox fx:id="comboOrigen" prefWidth="200.0" promptText="Seleccione partida..."/>

            <Label text="Destino:"/>
            <ComboBox fx:id="comboDestino" prefWidth="200.0" promptText="Seleccione destino..."/>

            <Label text="Optimizar por:"/>
            <ComboBox fx:id="comboCriterio" prefWidth="200.0" promptText="Seleccione criterio..."/>

            <Button fx:id="btnCalcular" text="Calcular Ruta Óptima" prefWidth="200.0"
                    style="-fx-background-color: #0078D7; -fx-text-fill: white; -fx-font-weight: bold;"
                    onAction="#calcularRuta"/>

            <Separator />
            <Button text="Gestionar Paradas/Rutas" prefWidth="200.0" onAction="#abrirGestor"/>
        </VBox>
    </left>

    <center>
        <Pane fx:id="mapaPane" style="-fx-background-color: #ffffff;">
        </Pane>
    </center>

    <bottom>
        <HBox spacing="30.0" style="-fx-background-color: #eeeeee; -fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>
            <Label fx:id="lblResultadoRuta" text="Ruta: N/A" style="-fx-font-weight: bold;"/>
            <Label fx:id="lblTiempo" text="Tiempo: 0 min"/>
            <Label fx:id="lblDistancia" text="Distancia: 0 km"/>
            <Label fx:id="lblCosto" text="Costo: $0.00"/>
        </HBox>
    </bottom>

</BorderPane>